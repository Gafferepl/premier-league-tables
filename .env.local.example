# Required for Gemini AI functionality
API_KEY=your_gemini_api_key_here

# Optional: For live football data from football-data.org
VITE_FOOTBALL_DATA_KEY=your_football_data_api_key_here

# Optional: For Twitter integration (cron jobs)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# Optional: For cron job security
CRON_SECRET=your_cron_secret_here

# ================================================================
# SECURITY CONFIGURATION
# ================================================================

# CORS Origins (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# Encryption key for sensitive data (32 characters minimum)
ENCRYPTION_KEY=your_32_character_encryption_key_here

# Session secret for authentication
SESSION_SECRET=your_session_secret_here

# Optional: For external API calls
API_FOOTBALL_KEY=your_api_football_key

# ================================================================
# ADVANCED ANALYTICS API KEYS (xG/xA Data Sources)
# ================================================================

# StatsBomb API (FREE - Recommended)
# Provides comprehensive xG/xA data, shot maps, and advanced metrics
# Get free API key from: https://statsbomb.com/api-docs/
STATSBOMB_API_KEY=your_statsbomb_api_key_here

# Understat API (FREE - Alternative)
# Provides xG data and shot maps for Premier League
# No API key required, but may need CORS proxy in production
# Data source: https://understat.com/

# FBref/StatsBomb Integration (FREE)
# FBref uses StatsBomb data - can scrape via server-side proxy
# No API key required, but requires server implementation
FBREF_PROXY_URL=http://localhost:3001/api/fbref

# Opta Analytics (PAID - Professional)
# Industry-standard advanced analytics data
# Requires commercial subscription
# Contact: https://theanalyst.com/opta/
OPTA_API_KEY=your_opta_api_key_here
OPTA_CLIENT_ID=your_opta_client_id_here

# WhoScored Analytics (PAID - Alternative)
# Advanced metrics and detailed player analysis
# Requires commercial subscription
# Contact: https://www.whoscored.com/
WHOSCORED_API_KEY=your_whoscored_api_key_here

# ================================================================
# ADVANCED ANALYTICS CONFIGURATION
# ================================================================

# Primary data source for xG/xA metrics
# Options: 'statsbomb', 'understat', 'fbref', 'opta', 'whoscored'
ADVANCED_ANALYTICS_SOURCE=statsbomb

# Cache duration for advanced analytics (in minutes)
# Longer cache = fewer API calls, less fresh data
ADVANCED_ANALYTICS_CACHE_MINUTES=15

# Enable real-time xG updates during matches
# Set to 'true' for live match xG tracking
ENABLE_LIVE_XG_UPDATES=false

# Fallback to mock data when APIs fail
# Set to 'false' to show errors instead of mock data
USE_MOCK_FALLBACK=true

# ================================================================
# EXPLANATION OF METRICS
# ================================================================

# xG (Expected Goals): Quality of scoring chances
# xA (Expected Assists): Quality of chance-creating actions  
# xGI (xG + xA): Overall attacking contribution
# xG per 90: Expected Goals per 90 minutes played
# xGA (Expected Goals Against): Quality of chances conceded
# xGD (xG Difference): xG - xGA (positive = good)
# PPDA: Passes Per Defensive Action (lower = more aggressive)
# Big Chances: High-quality scoring opportunities
# xG Chain: xG from build-up play sequences
# xG Buildup: xG from direct build-up actions
