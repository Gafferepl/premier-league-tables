                  <div className="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm text-yellow-700 dark:text-yellow-300">
                    <div className="flex items-center space-x-2">
                      <span>🏆</span>
                      <span>WHAT'S HAPPENING IN THE PREMIER LEAGUE</span>
                    </div>
                    <div className="flex items-center space-x-2">
                      <span>🧠</span>
                      <span>GAFFER'S INSIGHTS</span>
                    </div>
                    <div className="flex items-center space-x-2">
                      <span>📊</span>
                      <span>NEW MATCH PREDICTIONS ANNOUNCEMENT</span>
                    </div>
                    <div className="flex items-center space-x-2">
                      <span>⚽</span>
                      <span>TIPS AND TRICKS TO FANTASY LEAGUE PICKS</span>
                    </div>
                  </div>
                  <p className="text-xs text-yellow-600 dark:text-yellow-400 mt-3 text-center">
                    No spam - just weekly football fun!
                  </p>
                </div>
              </div>
            </div>
            
            {/* Sample Match Preview */}
            <div className="mb-8">
              <h3 className="text-lg font-bold text-primary dark:text-white mb-4 text-center">
                ⚽ Example Match Prediction
              </h3>
              <div className="bg-slate-100 dark:bg-slate-700 rounded-lg p-4">
                <div className="flex items-center justify-between">
                  <div className="flex items-center space-x-3">
                    <div className="w-8 h-8 bg-slate-300 dark:bg-slate-600 rounded-full"></div>
                    <span className="font-medium text-slate-700 dark:text-slate-200">Manchester City</span>
                  </div>
                  <span className="text-slate-500 dark:text-slate-400">vs</span>
                  <div className="flex items-center space-x-3">
                    <span className="font-medium text-slate-700 dark:text-slate-200">Liverpool</span>
                    <div className="w-8 h-8 bg-slate-300 dark:bg-slate-600 rounded-full"></div>
                  </div>
                </div>
                <div className="flex justify-center space-x-2 mt-3">
                  <button className="px-3 py-1 bg-slate-200 dark:bg-slate-600 rounded text-sm">🏠 Home</button>
                  <button className="px-3 py-1 bg-slate-200 dark:bg-slate-600 rounded text-sm">🤝 Draw</button>
                  <button className="px-3 py-1 bg-slate-200 dark:bg-slate-600 rounded text-sm">✈️ Away</button>
                </div>
                <div className="text-xs text-center text-slate-500 dark:text-slate-400 mt-2">
                  🧠 Gaffer predicts: Home
                </div>
              </div>
            </div>
            
            <div className="space-y-4">
              <button
                onClick={() => setGameState('signup')}
                className="w-full bg-accent hover:bg-accent/90 text-white font-bold py-4 px-8 rounded-lg text-lg transition-all transform hover:scale-105 shadow-lg"
              >
                📧 Sign Up & Start Playing
              </button>
              
              <button
                onClick={handleViewLeaderboard}
                className="w-full bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-200 font-bold py-3 px-6 rounded-lg transition-all"
              >
                👀 View Current Leaderboard
              </button>
            </div>
            
            <div className="mt-8 text-sm text-slate-500 dark:text-slate-400 text-center">
              <p>📊 Top 5 players announced every Sunday evening</p>
              <p>🧠 See how you compare against The Gaffer's predictions</p>
              <p>📧 Join thousands of football fans testing their knowledge!</p>
            </div>
          </div>
        </div>
        )}
      </div>
    );
  }

  if (gameState === 'signup') {
    return (
      <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div className="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl p-8 max-w-md w-full max-h-[90vh] overflow-y-auto">
          <h2 className="text-2xl font-bold text-primary dark:text-white mb-6 text-center">
            📧 Sign Up to Play
          </h2>
          
          <div className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Your Name
              </label>
              <input
                type="text"
                value={userProfile.name}
                onChange={(e) => setUserProfile({...userProfile, name: e.target.value})}
                className="w-full px-4 py-2 border border-slate-300 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent"
                placeholder="John Smith"
              />
            </div>
            
            <div>
              <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Email Address
              </label>
              <input
                type="email"
                value={userProfile.email}
                onChange={(e) => {
                  setUserProfile({...userProfile, email: e.target.value});
                  setEmailError(''); // Clear error on change
                }}
                className={`w-full px-4 py-2 border rounded-lg bg-white dark:bg-slate-700 text-slate-900 dark:text-white focus:ring-2 focus:ring-accent focus:border-transparent ${
                  emailError ? 'border-red-500' : 'border-slate-300 dark:border-slate-600'
                }`}
                placeholder="john@example.com"
              />
              {emailError && (
                <p className="text-red-500 text-sm mt-1">{emailError}</p>
              )}
            </div>
            
            <div>
              <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Favorite Club
              </label>
              <ClubDropdown
                value={userProfile.club}
                onChange={(club) => setUserProfile({...userProfile, club})}
              />
            </div>
            
            <div>
              <label className="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
                Country
              </label>
              <CountryDropdown
                value={userProfile.country}
                onChange={(country) => setUserProfile({...userProfile, country})}
              />
            </div>
            
            <div className="flex items-center">
              <input
                type="checkbox"
                id="terms"
                checked={agreeToEmails}
                onChange={(e) => setAgreeToEmails(e.target.checked)}
                className="mr-2"
              />
              <label htmlFor="terms" className="text-sm text-slate-600 dark:text-slate-400">
                I agree to receive weekly results emails
              </label>
            </div>
          </div>
          
          <div className="space-y-4 mt-6">
            <button
              onClick={handleSignup}
              disabled={!userProfile.name || !userProfile.email || !userProfile.club || !userProfile.country || !agreeToEmails}
              className={`w-full py-3 rounded-lg font-bold transition-all ${
                userProfile.name && userProfile.email && userProfile.club && userProfile.country && agreeToEmails && !emailError
                  ? 'bg-accent hover:bg-accent/90 text-white shadow-lg transform hover:scale-105'
                  : 'bg-slate-300 dark:bg-slate-600 text-slate-500 dark:text-slate-400 cursor-not-allowed'
              }`}
            >
              🎮 Start Playing
            </button>
            
            <button
              onClick={() => setGameState('intro')}
              className="w-full bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-200 font-bold py-3 px-6 rounded-lg transition-all"
            >
              ← Back
            </button>
          </div>
        </div>
      </div>
    );
  }

  if (gameState === 'playing') {
    return (
      <div ref={containerRef} className="min-h-screen bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 flex items-start justify-center p-4 pt-8">
        <div className="max-w-4xl w-full">
          <div className="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl p-6 mb-6">
            <div className="flex justify-between items-center mb-6">
              <h2 className="text-2xl font-bold text-primary dark:text-white">
                🧠 Beat The Gaffer - Predict 5 Matches
              </h2>
              <div className="text-sm text-slate-600 dark:text-slate-300">
                {predictions.length}/5 predictions
              </div>
            </div>
            
            <div className="space-y-4">
              {selectedMatches.map((match, index) => (
                <div key={match.id} className="bg-slate-50 dark:bg-slate-700 rounded-lg p-4">
                  <div className="flex items-center justify-between mb-3">
                    <div className="flex items-center space-x-3">
                      <div className="text-lg font-bold text-slate-700 dark:text-slate-200">
                        Match {index + 1}
                      </div>
                      <div className="text-xs text-slate-500 dark:text-slate-400">
                        {new Date(match.date).toLocaleDateString()}
                      </div>
                    </div>
                    <div className="text-xs bg-purple-100 dark:bg-purple-900/30 text-purple-800 dark:text-purple-200 px-2 py-1 rounded">
                      🧠 Gaffer: {getPredictionIcon(GAFFER_PREDICTIONS[match.id as keyof typeof GAFFER_PREDICTIONS])} {getPredictionText(GAFFER_PREDICTIONS[match.id as keyof typeof GAFFER_PREDICTIONS], match.homeTeam, match.awayTeam)}
                    </div>
                  </div>
                  
                  <div className="flex items-center justify-between">
                    <div className="flex items-center space-x-4">
                      <LogoWithFallback 
                        src={getTeamLogo(match.homeTeam)} 
                        teamName={match.homeTeam} 
                        size="w-10 h-10 md:w-12 md:h-12" 
                        className="transition-transform duration-300 group-hover:scale-110 filter drop-shadow-sm group-hover:drop-shadow-md" 
                      />
                      <span className="font-medium text-slate-700 dark:text-slate-200">{match.homeTeam}</span>
                    </div>
                    
                    <span className="text-slate-500 dark:text-slate-400 font-heading">vs</span>
                    
                    <div className="flex items-center space-x-4">
                      <span className="font-medium text-slate-700 dark:text-slate-200">{match.awayTeam}</span>
                      <LogoWithFallback 
                        src={getTeamLogo(match.awayTeam)} 
                        teamName={match.awayTeam} 
                        size="w-10 h-10 md:w-12 md:h-12" 
                        className="transition-transform duration-300 group-hover:scale-110 filter drop-shadow-sm group-hover:drop-shadow-md" 
                      />
                    </div>
                  </div>
                  
                  <div className="flex space-x-2">
                      {(['home', 'draw', 'away'] as const).map((prediction) => (
                        <button
                          key={prediction}
                          onClick={() => handlePrediction(match.id, prediction)}
                          className={`px-4 py-2 rounded-lg font-medium transition-all ${
                            predictions.find(p => p.matchId === match.id)?.prediction === prediction
                              ? 'bg-accent text-white shadow-lg transform scale-105'
                              : 'bg-slate-200 dark:bg-slate-600 text-slate-700 dark:text-slate-200 hover:bg-slate-300 dark:hover:bg-slate-500'
                          }`}
                        >
                          {getPredictionIcon(prediction)} {getPredictionText(prediction, match.homeTeam, match.awayTeam)}
                        </button>
                      ))}
                    </div>
                  </div>
              ))}
            </div>
            
            <div className="mt-6 flex justify-between items-center">
              <div className="text-sm text-slate-500 dark:text-slate-400">
                💡 Tip: The Gaffer gets 2 points for correct predictions. Can you beat the expert?
              </div>
              <button
                onClick={handleCompleteGame}
                disabled={predictions.length !== 5}
                className={`px-6 py-3 rounded-lg font-bold transition-all ${
                  predictions.length === 5
                    ? 'bg-accent hover:bg-accent/90 text-white shadow-lg transform hover:scale-105'
                    : 'bg-slate-300 dark:bg-slate-600 text-slate-500 dark:text-slate-400 cursor-not-allowed'
                }`}
              >
                {predictions.length === 5 ? buttonText : `Make ${5 - predictions.length} more predictions`}
              </button>
            </div>
          </div>
        </div>
      </div>
    );
  }

  // Generate dynamic Gaffer banter based on predictions
  const generateGafferBanter = (userPreds: any[], gafferPreds: any): string => {
    const disagreements = userPreds.filter(pred => {
      const gafferPred = gafferPreds[pred.matchId as keyof typeof gafferPreds];
      return pred.prediction !== gafferPred;
    }).length;

    const awayPicks = userPreds.filter(pred => pred.prediction === 'away').length;
    const homePicks = userPreds.filter(pred => pred.prediction === 'home').length;
    const drawPicks = userPreds.filter(pred => pred.prediction === 'draw').length;

    // Dynamic banter based on user's actual choices
    if (disagreements === 0) {
      return "Great minds think alike! Though I've been doing this since you were in short trousers. Copycat!";
    } else if (disagreements === 1) {
      return "Only one disagreement? Playing it safe are we? One brave pick amongst the sheep following the shepherd!";
    } else if (disagreements === 2) {
      return "Going against the gaffer twice! Either you're a genius or you'll be buying the pies this weekend. Bold!";
    } else if (disagreements >= 3) {
      return "Three or more disagreements? You've got bigger cojones than a bull in a china shop! Respect the confidence, son!";
    }

    if (awayPicks >= 3) {
      return "Backing all the away teams? Either you've got inside information or you're just plain daft! Away wins are for gamblers!";
    }

    if (homePicks >= 4) {
      return "Playing it safe with all the home wins? No imagination, son! Sometimes you've got to take a chance or you'll never beat the gaffer!";
    }

    if (drawPicks >= 3) {
      return "Three or more draws? Sitting on the fence are we? Make a decision! Draws are for people who can't make their mind up!";
    }

    return "Interesting picks... I've seen worse, but not many! Let's see if your bravery pays off or if you're just helping my pension fund!";
  };

  // Calculate risk level based on predictions
  const calculateRiskLevel = (userPreds: any[]): string => {
    const awayPicks = userPreds.filter(pred => pred.prediction === 'away').length;
    const disagreements = userPreds.filter(pred => {
      const gafferPred = GAFFER_PREDICTIONS[pred.matchId as keyof typeof GAFFER_PREDICTIONS];
      return pred.prediction !== gafferPred;
    }).length;

    if (awayPicks >= 3 || disagreements >= 3) return "BOLD ⚡⚡⚡";
    if (awayPicks >= 2 || disagreements >= 2) return "ADVENTUROUS ⚡⚡";
    if (awayPicks >= 1 || disagreements >= 1) return "CAUTIOUS ⚡";
    return "CONSERVATIVE 😴";
  };

  if (gameState === 'results') {

  const beatGaffer = userScore > gafferScore;
    
    return (
      <div ref={containerRef} className="min-h-screen bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 flex items-start justify-center p-4 pt-8">
        <div className="max-w-2xl w-full">
          <div className="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl p-8 text-center">
            <div className="mb-8">
              <h2 className="text-3xl font-bold text-primary dark:text-white mb-4">
                🧠 The Gaffer's Pre-Match Analysis
              </h2>
              
              {/* Dynamic Gaffer Analysis */}
              <div className="bg-orange-100 dark:bg-orange-900/30 rounded-lg p-4 mb-6">
                <div className="text-2xl mb-2">🧠</div>
                <div className="text-lg font-bold text-orange-800 dark:text-orange-200">
                  The Gaffer's Verdict
                </div>
                
                <div className="text-sm text-orange-700 dark:text-orange-300 mb-3">
                  Your Risk Level: {calculateRiskLevel(predictions)}
                </div>
                
                <div className="text-xs text-orange-600 dark:text-orange-400 italic">
                  "{generateGafferBanter(predictions, GAFFER_PREDICTIONS)}"
                </div>
              </div>
              
              {/* Prediction Breakdown */}
              <div className="bg-slate-100 dark:bg-slate-700 rounded-lg p-4 mb-6">
                <div className="text-sm font-bold text-slate-700 dark:text-slate-200 mb-3">
                  📊 Prediction Breakdown:
                </div>
                <div className="grid grid-cols-3 gap-4 text-center">
                  <div>
                    <div className="text-2xl font-bold text-blue-600 dark:text-blue-400">
                      {predictions.filter(p => p.prediction === 'home').length}
                    </div>
                    <div className="text-xs text-blue-800 dark:text-blue-200">
                      Home Wins
                    </div>
                  </div>
                  <div>
                    <div className="text-2xl font-bold text-green-600 dark:text-green-400">
                      {predictions.filter(p => p.prediction === 'draw').length}
                    </div>
                    <div className="text-xs text-green-800 dark:text-green-200">
                      Draws
                    </div>
                  </div>
                  <div>
                    <div className="text-2xl font-bold text-red-600 dark:text-red-400">
                      {predictions.filter(p => p.prediction === 'away').length}
                    </div>
                    <div className="text-xs text-red-800 dark:text-red-200">
                      Away Wins
                    </div>
                  </div>
                </div>
              </div>
              
              <div className="text-center">
                <p className="text-slate-600 dark:text-slate-300 mb-4">
                  📅 COME BACK SUNDAY NIGHT TO SEE IF YOU BEAT THE GAFFER!
                </p>
                <button
                  onClick={resetGame}
                  className="bg-accent hover:bg-accent/90 text-white font-bold py-3 px-6 rounded-lg transition-all"
                >
                  🔄 Play Again
                </button>
              </div>
            </div>
            
            {/* Sunday Message */}
            <div className="bg-slate-100 dark:bg-slate-700 rounded-lg p-4 mb-6">
              <p className="text-slate-700 dark:text-slate-200 font-medium">
                📅 CHECK BACK SUNDAY NIGHT IF YOU MADE IT TO THE LEADERBOARD AND BEAT THE GAFFER!
              </p>
              <p className="text-sm text-slate-600 dark:text-slate-300 mt-2">
                The Gaffer will announce the top 5 performers after all Sunday games are finished.
              </p>
            </div>
            
            <div className="space-y-4">
              <button
                onClick={() => setGameState('leaderboard')}
                className="w-full bg-accent hover:bg-accent/90 text-white font-bold py-4 px-6 rounded-lg text-lg transition-all transform hover:scale-105 shadow-lg"
              >
                🏆 View Current Leaderboard
              </button>
              
              <button
                onClick={resetGame}
                className="w-full bg-slate-200 dark:bg-slate-700 text-slate-700 dark:text-slate-200 font-bold py-3 px-6 rounded-lg transition-all"
              >
                🔄 Play Again
              </button>
            </div>
          </div>
        </div>
      </div>
    );
  }

  if (gameState === 'leaderboard') {
    return (
      <div ref={containerRef} className="min-h-screen bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 flex items-start justify-center p-4 pt-8">
        <div className="max-w-4xl w-full">
          <div className="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl p-8">
            <h2 className="text-3xl font-bold text-primary dark:text-white mb-8 text-center">
              🏆 Weekly Leaderboard
            </h2>
            
            {/* Gaffer's Score Section */}
            <div className="bg-purple-50 dark:bg-purple-900/20 rounded-lg p-6 mb-8">
              <div className="flex items-center justify-between">
                <div className="flex items-center space-x-4">
                  <div className="text-4xl">🧠</div>
                  <div>
                    <div className="text-xl font-bold text-purple-800 dark:text-purple-200">
                      The Gaffer
                    </div>
                    <div className="text-sm text-purple-600 dark:text-purple-300">
                      Expert Predictor
                    </div>
                    <div className="text-xs text-purple-500 dark:text-purple-400 mt-1 italic">
                      "Look, I can't play for them... but I'm usually right. Usually."
                    </div>
                  </div>
                </div>
                <div className="text-right">
                  <div className="text-3xl font-bold text-purple-600 dark:text-purple-400">
                    {gafferScore}
                  </div>
                  <div className="text-sm text-purple-600 dark:text-purple-300">
                    Points
                  </div>
                </div>
              </div>
            </div>
            
            {/* Top 5 Users */}
            <div className="space-y-3">
              {MOCK_LEADERBOARD.map((entry) => (
                <div key={entry.rank} className={`flex items-center justify-between p-4 rounded-lg ${
                  entry.rank === 1 ? 'bg-yellow-50 dark:bg-yellow-900/20 border-2 border-yellow-400' :
                  entry.rank === 2 ? 'bg-slate-100 dark:bg-slate-700' :
                  entry.rank === 3 ? 'bg-orange-50 dark:bg-orange-900/20' :
                  'bg-slate-50 dark:bg-slate-800'
                }`}>
                  <div className="flex items-center space-x-4">
                    <div className={`text-2xl font-bold ${
                      entry.rank === 1 ? 'text-yellow-600 dark:text-yellow-400' :
                      entry.rank === 2 ? 'text-slate-600 dark:text-slate-400' :
                      entry.rank === 3 ? 'text-orange-600 dark:text-orange-400' :
                      'text-slate-500 dark:text-slate-400'
                    }`}>
                      #{entry.rank}
                    </div>
                    
                    <div className="flex items-center space-x-3">
                      {/* National Flag in Circle */}
                      <div className="relative">
                        <div className="w-10 h-10 rounded-full overflow-hidden bg-slate-100 dark:bg-slate-700 flex items-center justify-center ring-2 ring-slate-200 dark:ring-slate-600">
                          <img 
                            src={COUNTRY_FLAGS[entry.country] || 'https://flagcdn.com/w40/gb.png'} 
                            alt={entry.country}
                            className="w-full h-full object-cover"
                            onError={(e: React.SyntheticEvent<HTMLImageElement>) => {
                              e.currentTarget.src = 'https://flagcdn.com/w40/gb.png';
                            }}
                          />
                        </div>
                      </div>
                      
                      {/* Club Logo */}
                      <LogoWithFallback 
                        src={getTeamLogo(entry.club)} 
                        teamName={entry.club} 
                        size="w-10 h-10" 
                        className="ring-2 ring-slate-200 dark:ring-slate-600" 
                      />
                      
                      <div>
                        <div className="font-bold text-slate-800 dark:text-slate-200">
                          {entry.name}
                        </div>
                        <div className="text-sm text-slate-600 dark:text-slate-400">
                          {entry.club}
                        </div>
                      </div>
                    </div>
                  </div>
                  
                  <div className="flex items-center space-x-4">
                    {entry.beatGaffer && (
                      <div className="bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-200 px-2 py-1 rounded text-xs font-bold">
                        🧠 Beat Gaffer!
                      </div>
                    )}
                    <div className="text-right">
                      <div className="text-xl font-bold text-slate-800 dark:text-slate-200">
                        {entry.points}
                      </div>
                      <div className="text-xs text-slate-600 dark:text-slate-400">
                        points
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            
            {/* User's Position */}
            {userProfile.name && (
              <div className="mt-8 p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                <div className="flex items-center justify-between">
                  <div className="flex items-center space-x-4">
                    <div className="w-8 h-8 rounded-full overflow-hidden bg-slate-100 dark:bg-slate-700 flex items-center justify-center">
                      <img 
                        src={COUNTRY_FLAGS[userProfile.country] || 'https://flagcdn.com/w40/gb.png'} 
                        alt={userProfile.country}
                        className="w-full h-full object-cover"
                        onError={(e: React.SyntheticEvent<HTMLImageElement>) => {
                          e.currentTarget.src = 'https://flagcdn.com/w40/gb.png';
                        }}
                      />
                    </div>
                    <div>
                      <div className="font-bold text-blue-800 dark:text-blue-200">
                        Your Position
                      </div>
                      <div className="text-sm text-blue-600 dark:text-blue-300">
                        {userProfile.name} ({userProfile.club})
                      </div>
                    </div>
                  </div>
                  <div className="text-right">
                    <div className="text-2xl font-bold text-blue-600 dark:text-blue-400">
                      {userScore}
                    </div>
                    <div className="text-xs text-blue-600 dark:text-blue-300">
                      points
                    </div>
                  </div>
                </div>
              </div>
            )}
            
            <div className="mt-8 text-center">
              <p className="text-sm text-slate-600 dark:text-slate-400 mb-4">
                📧 Weekly results emailed every Sunday evening
              </p>
              <button
                onClick={resetGame}
                className="bg-accent hover:bg-accent/90 text-white font-bold py-3 px-6 rounded-lg transition-all transform hover:scale-105"
              >
                🎮 Play Again Next Week
              </button>
            </div>
          </div>
        </div>
      </div>
    );
  }

  return null;
};

export default BeatTheGafferNew;
