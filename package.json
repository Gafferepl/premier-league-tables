{
  "name": "premier-league-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "build:prod": "tsc -p tsconfig.json && vite build --mode production",
    "build:secure": "tsc -p tsconfig.json && vite build --config vite.config.prod.ts",
    "build:seo": "tsc -p tsconfig.json && vite build --config vite.config.prod.ts && npm run lighthouse",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "install:optional": "npm install @sentry/browser redis",
    "security:check": "npm audit && echo 'Security audit complete'",
    "security:fix": "npm audit fix",
    "protect:move-docs": "mkdir -p docs/internal docs/private && mv docs/GAFFER_CHAT_REPLIES.md docs/internal/ 2>/dev/null || true && mv docs/SUPABASE_SETUP.md docs/internal/ 2>/dev/null || true",
    "protect:remove-logs": "find src -name '*.ts' -o -name '*.tsx' | xargs sed -i 's/console\\.log(/\\/\\/ console.log(/g' 2>/dev/null || true",
    "lighthouse": "lhci autorun --config=.lighthouserc.json",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json --upload.target=temporary-public-storage",
    "test:performance": "npm run build:seo && npm run lighthouse",
    "test:mobile": "npm run build && npm run preview",
    "deploy:staging": "npm run build:secure && echo 'Staging build complete'",
    "deploy:production": "npm run build:seo && echo 'Production build complete'",
    "seo:audit": "npm run build && npx @lhci/cli@0.12.x autorun --config=.lighthouserc.json",
    "perf:monitor": "npm run build && npx bundle-analyzer dist/static/js/*.js",
    "mobile:test": "npm run build && npx lighthouse --chrome-flags='--headless' --output=json --output-path=./lighthouse-mobile.json --emulated-form-factor=mobile dist/index.html"
  },
  "dependencies": {
    "@google/genai": "^0.2.0",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/dompurify": "^3.0.5",
    "@types/node-cron": "^3.0.11",
    "@types/react-beautiful-dnd": "^13.1.8",
    "react-helmet-async": "^2.0.4",
    "web-vitals": "^3.5.0",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.6.7",
    "cors": "^2.8.6",
    "date-fns": "^3.3.1",
    "dompurify": "^3.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "groq-sdk": "^1.1.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "openai": "^6.29.0",
    "react": "^18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.3.1",
    "stripe": "^20.4.1",
    "twitter-api-v2": "^1.16.0"
  },
  "optionalDependencies": {
    "@sentry/browser": "^7.120.4",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "dotenv": "^16.4.5",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^0.19.0"
  }
}
